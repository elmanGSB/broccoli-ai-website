---
// src/components/Hero.astro
---

<!-- ─── HERO ─── -->
<section class="hero">
  <div class="hero-text">
    <div class="hero-eyebrow">AI Agents for Independent Food Distribution</div>
    <h1 class="hero-headline">The AI operating layer for food distributors.</h1>
    <p class="hero-subheadline">Broccolli AI deploys four specialized agents across sales, buying, knowledge, and collections so your team spends less time on admin and more time protecting margin.</p>
    <div class="hero-cta-group">
      <a href="#cta" class="hero-cta">Book a Demo</a>
      <a href="#pillars" class="hero-cta-secondary">See the Agents</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="neural-canvas">
      <svg class="neural-svg" viewBox="0 0 600 700" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="intel-grid" width="32" height="32" patternUnits="userSpaceOnUse">
            <circle cx="16" cy="16" r="0.6" fill="#6b8f71" opacity="0.12"/>
          </pattern>
          <radialGradient id="center-glow" cx="50%" cy="47%" r="38%">
            <stop offset="0%" stop-color="#6b8f71" stop-opacity="0.14"/>
            <stop offset="50%" stop-color="#6b8f71" stop-opacity="0.04"/>
            <stop offset="100%" stop-color="#6b8f71" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="conn-sage-glow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#4a6e50" stop-opacity="0.5"/>
            <stop offset="50%" stop-color="#6b8f71" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#4a6e50" stop-opacity="0.5"/>
          </linearGradient>
          <linearGradient id="conn-terra-glow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#a86840" stop-opacity="0.45"/>
            <stop offset="50%" stop-color="#c67a4b" stop-opacity="0.12"/>
            <stop offset="100%" stop-color="#a86840" stop-opacity="0.45"/>
          </linearGradient>
          <filter id="node-shadow" x="-50%" y="-50%" width="200%" height="200%">
            <feDropShadow dx="0" dy="2" stdDeviation="8" flood-color="#6b8f71" flood-opacity="0.2"/>
          </filter>
          <filter id="strong-shadow" x="-100%" y="-100%" width="300%" height="300%">
            <feDropShadow dx="0" dy="3" stdDeviation="16" flood-color="#6b8f71" flood-opacity="0.15"/>
          </filter>
          <filter id="pulse-glow" x="-200%" y="-200%" width="500%" height="500%">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <rect width="600" height="700" fill="url(#intel-grid)"/>
        <rect width="600" height="700" fill="url(#center-glow)"/>

        <circle class="wave-ring w1" cx="300" cy="330" r="30" fill="none" stroke="#6b8f71" stroke-width="1"/>
        <circle class="wave-ring w2" cx="300" cy="330" r="30" fill="none" stroke="#6b8f71" stroke-width="0.8"/>
        <circle class="wave-ring w3" cx="300" cy="330" r="30" fill="none" stroke="#8aad90" stroke-width="0.6"/>

        <g class="orbit-ring">
          <ellipse cx="300" cy="330" rx="155" ry="140" fill="none" stroke="#6b8f71" stroke-width="0.5" opacity="0.15" stroke-dasharray="4 8"/>
          <circle cx="455" cy="330" r="2.5" fill="#6b8f71" opacity="0.4"/>
          <circle cx="145" cy="330" r="2" fill="#8aad90" opacity="0.3"/>
        </g>
        <g class="orbit-ring reverse">
          <ellipse cx="300" cy="330" rx="210" ry="195" fill="none" stroke="#c67a4b" stroke-width="0.4" opacity="0.1" stroke-dasharray="3 12"/>
          <circle cx="510" cy="330" r="2" fill="#c67a4b" opacity="0.3"/>
        </g>

        <circle class="brain-ring r1" cx="300" cy="330" r="70" fill="#6b8f71" opacity="0.06"/>
        <circle class="brain-ring r2" cx="300" cy="330" r="52" fill="#6b8f71" opacity="0.09"/>
        <circle class="brain-ring r3" cx="300" cy="330" r="36" fill="#6b8f71" opacity="0.12"/>

        <path class="neural-connection c1" d="M300 330 Q235 240 175 175" stroke="url(#conn-sage-glow)" stroke-width="2.5" fill="none" filter="url(#node-shadow)"/>
        <path class="neural-connection c2" d="M300 330 Q380 250 445 185" stroke="url(#conn-sage-glow)" stroke-width="2.5" fill="none" filter="url(#node-shadow)"/>
        <path class="neural-connection c3" d="M300 330 Q215 405 145 475" stroke="url(#conn-sage-glow)" stroke-width="2.5" fill="none" filter="url(#node-shadow)"/>
        <path class="neural-connection c4" d="M300 330 Q395 415 465 485" stroke="url(#conn-sage-glow)" stroke-width="2.5" fill="none" filter="url(#node-shadow)"/>
        <path class="neural-connection c5" d="M175 175 Q115 130 70 105" stroke="url(#conn-terra-glow)" stroke-width="1.5" fill="none"/>
        <path class="neural-connection c6" d="M175 175 Q130 250 100 310" stroke="#6b8f71" stroke-width="1.2" fill="none" opacity="0.25"/>
        <path class="neural-connection c7" d="M445 185 Q490 130 525 90" stroke="url(#conn-terra-glow)" stroke-width="1.5" fill="none"/>
        <path class="neural-connection c8" d="M445 185 Q490 255 510 320" stroke="#6b8f71" stroke-width="1.2" fill="none" opacity="0.25"/>
        <path class="neural-connection c9" d="M145 475 Q100 520 75 565" stroke="url(#conn-terra-glow)" stroke-width="1.5" fill="none"/>
        <path class="neural-connection c10" d="M145 475 Q195 520 200 570" stroke="#6b8f71" stroke-width="1.2" fill="none" opacity="0.25"/>
        <path class="neural-connection c11" d="M465 485 Q510 525 545 565" stroke="url(#conn-terra-glow)" stroke-width="1.5" fill="none"/>
        <path class="neural-connection c12" d="M465 485 Q430 540 420 580" stroke="#6b8f71" stroke-width="1.2" fill="none" opacity="0.25"/>
        <!-- Fix A: renamed duplicate c5 → ch1 -->
        <path class="neural-connection ch1" d="M175 175 Q300 150 445 185" stroke="#6b8f71" stroke-width="0.9" fill="none" opacity="0.2"/>
        <!-- Fix B: renamed duplicate c6 → ch2 -->
        <path class="neural-connection ch2" d="M145 475 Q300 510 465 485" stroke="#6b8f71" stroke-width="0.9" fill="none" opacity="0.2"/>

        <circle r="4.5" fill="#4a6e50" filter="url(#pulse-glow)">
          <animateMotion dur="2.8s" repeatCount="indefinite" begin="1.2s"><mpath href="#pp1"/></animateMotion>
          <animate attributeName="opacity" values="0;0.75;0.75;0" dur="2.8s" repeatCount="indefinite" begin="1.2s"/>
        </circle>
        <path id="pp1" d="M300 330 Q235 240 175 175" fill="none"/>
        <circle r="4.5" fill="#6b8f71" filter="url(#pulse-glow)">
          <animateMotion dur="3s" repeatCount="indefinite" begin="2s"><mpath href="#pp2"/></animateMotion>
          <animate attributeName="opacity" values="0;0.75;0.75;0" dur="3s" repeatCount="indefinite" begin="2s"/>
        </circle>
        <path id="pp2" d="M300 330 Q380 250 445 185" fill="none"/>
        <circle r="4" fill="#c67a4b" filter="url(#pulse-glow)">
          <animateMotion dur="3.2s" repeatCount="indefinite" begin="2.5s"><mpath href="#pp3"/></animateMotion>
          <animate attributeName="opacity" values="0;0.7;0.7;0" dur="3.2s" repeatCount="indefinite" begin="2.5s"/>
        </circle>
        <path id="pp3" d="M300 330 Q215 405 145 475" fill="none"/>
        <circle r="4.5" fill="#4a6e50" filter="url(#pulse-glow)">
          <animateMotion dur="2.6s" repeatCount="indefinite" begin="1.6s"><mpath href="#pp4"/></animateMotion>
          <animate attributeName="opacity" values="0;0.75;0.75;0" dur="2.6s" repeatCount="indefinite" begin="1.6s"/>
        </circle>
        <path id="pp4" d="M300 330 Q395 415 465 485" fill="none"/>
        <circle r="3.5" fill="#6b8f71" filter="url(#pulse-glow)">
          <animateMotion dur="3.5s" repeatCount="indefinite" begin="3s"><mpath href="#pp5"/></animateMotion>
          <animate attributeName="opacity" values="0;0.6;0.6;0" dur="3.5s" repeatCount="indefinite" begin="3s"/>
        </circle>
        <path id="pp5" d="M175 175 Q235 240 300 330" fill="none"/>

        <g class="node-group n1">
          <circle cx="300" cy="330" r="40" fill="#6b8f71" opacity="0.08" filter="url(#strong-shadow)"/>
          <circle cx="300" cy="330" r="26" fill="#6b8f71" opacity="0.18"/>
          <circle cx="300" cy="330" r="16" fill="#6b8f71" opacity="0.45"/>
          <circle class="node-core" cx="300" cy="330" r="10" fill="#4a6e50" filter="url(#node-shadow)"/>
          <circle cx="296" cy="327" r="2.5" fill="#faf8f4" opacity="0.85"/>
          <circle cx="304" cy="327" r="2.5" fill="#faf8f4" opacity="0.7"/>
          <circle cx="300" cy="334" r="2" fill="#faf8f4" opacity="0.55"/>
        </g>
        <g class="node-group n2">
          <circle cx="175" cy="175" r="30" fill="#6b8f71" opacity="0.07" filter="url(#node-shadow)"/>
          <circle cx="175" cy="175" r="18" fill="#6b8f71" opacity="0.16"/>
          <circle class="node-core" cx="175" cy="175" r="10" fill="#6b8f71" filter="url(#node-shadow)"/>
          <circle cx="175" cy="175" r="4" fill="#faf8f4" opacity="0.7"/>
          <text class="node-label l1" x="175" y="140" text-anchor="middle" fill="#4a6e50" opacity="0.65">Sales</text>
        </g>
        <g class="node-group n3">
          <circle cx="445" cy="185" r="30" fill="#c67a4b" opacity="0.07" filter="url(#node-shadow)"/>
          <circle cx="445" cy="185" r="18" fill="#c67a4b" opacity="0.15"/>
          <circle class="node-core" cx="445" cy="185" r="10" fill="#c67a4b" filter="url(#node-shadow)"/>
          <circle cx="445" cy="185" r="4" fill="#faf8f4" opacity="0.7"/>
          <text class="node-label l2" x="445" y="152" text-anchor="middle" fill="#a86840" opacity="0.6">Suppliers</text>
        </g>
        <g class="node-group n4">
          <circle cx="145" cy="475" r="30" fill="#6b8f71" opacity="0.07" filter="url(#node-shadow)"/>
          <circle cx="145" cy="475" r="18" fill="#6b8f71" opacity="0.16"/>
          <circle class="node-core" cx="145" cy="475" r="10" fill="#6b8f71" filter="url(#node-shadow)"/>
          <circle cx="145" cy="475" r="4" fill="#faf8f4" opacity="0.7"/>
          <text class="node-label l3" x="145" y="515" text-anchor="middle" fill="#4a6e50" opacity="0.65">Knowledge</text>
        </g>
        <g class="node-group n5">
          <!-- Fix D: removed duplicate fill attribute, kept fill="none" -->
          <circle cx="465" cy="485" r="30" fill="none" opacity="0.07"/>
          <circle cx="465" cy="485" r="18" fill="#c67a4b" opacity="0.15"/>
          <circle class="node-core" cx="465" cy="485" r="10" fill="#c67a4b" filter="url(#node-shadow)"/>
          <circle cx="465" cy="485" r="4" fill="#faf8f4" opacity="0.7"/>
          <text class="node-label l4" x="465" y="525" text-anchor="middle" fill="#a86840" opacity="0.6">Payments</text>
        </g>
        <g class="node-group n6">
          <circle cx="70" cy="105" r="14" fill="#6b8f71" opacity="0.06"/>
          <circle cx="70" cy="105" r="6" fill="#6b8f71" opacity="0.35"/>
        </g>
        <g class="node-group n7">
          <circle cx="100" cy="310" r="10" fill="#6b8f71" opacity="0.05"/>
          <circle cx="100" cy="310" r="4.5" fill="#8aad90" opacity="0.35"/>
        </g>
        <!-- Fix C: renamed duplicate n6 → n8 -->
        <g class="node-group n8">
          <circle cx="525" cy="90" r="14" fill="#c67a4b" opacity="0.06"/>
          <circle cx="525" cy="90" r="6" fill="#c67a4b" opacity="0.3"/>
        </g>
      </svg>
      <div class="hero-food-core" aria-hidden="true">
        <div class="food-viewport">
          <div class="food-sprite one">
            <!-- Fix E: local images with lazy loading -->
            <img src="/images/tomatoes.jpg" alt="" loading="lazy" />
          </div>
          <div class="food-sprite two">
            <img src="/images/lettuce.jpg" alt="" loading="lazy" />
          </div>
          <div class="food-sprite three">
            <img src="/images/carrots.jpg" alt="" loading="lazy" />
          </div>
          <div class="food-sprite four">
            <img src="/images/cheese.jpg" alt="" loading="lazy" />
          </div>
          <div class="food-sprite five">
            <img src="/images/lemon.jpg" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
