---
// src/components/Results.astro
---

<section class="results-section" id="results">
  <div class="results-inner">
    <div class="results-header">
      <div>
        <div class="section-eyebrow">Where Time Gets Lost</div>
        <h2 class="results-title">The time drain is already measurable.</h2>
      </div>
      <p class="results-context">Research shows the same pattern across sales, buying, and knowledge work: teams lose hours to admin and answer-hunting before revenue work even starts. Broccolli AI is built to give that time back.</p>
    </div>

    <div class="results-grid">
      <article class="results-card orange">
        <div class="results-number">60<span class="results-suffix">%</span></div>
        <p class="results-label">of a sales rep's time goes to non-selling work</p>
        <div class="results-source">Salesforce · State of Sales 2026</div>
      </article>

      <article class="results-card green">
        <div class="results-number">39<span class="results-suffix">%</span></div>
        <p class="results-label">less admin time for procurement leaders who automate routine tasks</p>
        <div class="results-source">Portland Procurement Value Survey · 2025</div>
      </article>

      <article class="results-card blue">
        <div class="results-number">5<span class="results-suffix">hrs</span></div>
        <p class="results-label">per week knowledge workers spend searching for information online</p>
        <div class="results-source">McKinsey · The Impact of Internet Technologies</div>
      </article>

      <article class="results-card yellow">
        <div class="results-number">19<span class="results-suffix">%</span></div>
        <p class="results-label">of business data is inaccessible when teams need it most</p>
        <div class="results-source">Salesforce · State of Data &amp; Analytics</div>
      </article>
    </div>
  </div>
</section>
