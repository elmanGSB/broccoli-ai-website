}
.pillar-card.selected {
  border-color: var(--sage);
  background: rgba(107,143,113,0.05);
  box-shadow: 0 0 0 3px rgba(107,143,113,0.12), 0 6px 20px rgba(107,143,113,0.14);
}
.card-svg-wrap {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: rgba(245,240,232,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px;
}
.card-svg {
  width: 40px;
  height: 40px;
}
.card-content {
  flex: 1;
  min-width: 0;
}
.card-kicker {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 4px;
}
.card-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
  line-height: 1.2;
}
.card-label {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.45;
}
.card-check {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--sage);
  color: white;
  font-size: 12px;
  font-weight: 700;
  display: none;
  align-items: center;
  justify-content: center;
}
.pillar-card.selected .card-check,
.custom-card.selected .card-check {
  display: flex;
}

/* ── Custom Card ── */
.custom-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 28px;
  border-radius: 18px;
  border: 1.5px solid rgba(198,122,75,0.35);
  background: #1a1208;
  cursor: pointer;
  transition: all 0.22s ease;
  box-shadow: 0 2px 16px rgba(26,18,8,0.2);
}
.custom-card:hover {
  border-color: var(--terra);
  box-shadow: 0 8px 24px rgba(26,18,8,0.28);
  transform: translateY(-2px);
}
.custom-card.selected {
  border-color: var(--terra);
  box-shadow: 0 0 0 3px rgba(198,122,75,0.2), 0 8px 24px rgba(26,18,8,0.28);
}
.custom-card-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.custom-kicker {
  color: rgba(198,122,75,0.75);
}
.custom-card-title {
  font-size: 18px;
  font-weight: 700;
  color: rgba(245,240,232,0.95);
  line-height: 1.2;
}
.custom-card-sub {
  font-size: 13px;
  color: rgba(245,240,232,0.5);
  line-height: 1.5;
  max-width: 400px;
}
.custom-sparkle {
  font-size: 32px;
  color: rgba(198,122,75,0.6);
  flex-shrink: 0;
  margin-left: 20px;
  margin-right: 8px;
  line-height: 1;
}

/* ── Step 2 footer ── */
.step2-footer,
.step3-footer {
  margin-top: 32px;
}
.step3-footer {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10px;
}
.step3-skip-hint {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}
.step3-skip-link {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.2s;
}
.step3-skip-link:hover {
  color: var(--sage);
}

/* ── Calendar ── */
.calendar-wrap {
  position: relative;
  width: 100%;
  height: 540px;
  border-radius: 18px;
  border: 1.5px solid rgba(107,143,113,0.18);
  background: var(--white);
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(92,64,51,0.08);
}
.calendar-iframe {
  width: 100%;
  height: 100%;
  display: block;
  border: none;
}
.calendar-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  background: var(--white);
  pointer-events: none;
}
.cal-placeholder-icon {
  font-size: 48px;
}
.cal-placeholder-text {
  font-size: 15px;
  color: var(--text-muted);
  font-weight: 500;
}

/* ── Step 4: Confirm ── */
.confirm-mark-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}
.confirm-mark {
  width: 80px;
  height: 80px;
}
.confirm-mark circle {
  stroke-dasharray: 200;
  stroke-dashoffset: 200;
}
.confirm-mark path {
  stroke-dasharray: 60;
  stroke-dashoffset: 60;
}
.confirm-mark.animate circle {
  animation: draw-circle 0.5s ease-out 0.1s forwards;
}
.confirm-mark.animate path {
  animation: draw-check 0.35s ease-out 0.55s forwards;
}
@keyframes draw-circle { to { stroke-dashoffset: 0; } }
@keyframes draw-check  { to { stroke-dashoffset: 0; } }

.confirm-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.confirm-headline {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 5vw, 54px);
  font-weight: 700;
  letter-spacing: -1.8px;
  color: var(--text);
  line-height: 1.06;
}
.confirm-sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--text-body);
  max-width: 400px;
}
.pillar-tag-wrap {
  margin-top: 4px;
}
.pillar-tag {
  display: inline-block;
  padding: 8px 18px;
  border-radius: 999px;
  background: var(--sage-faint);
  color: var(--sage-deep);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

/* ── What happens next ── */
.whats-next {
  width: 100%;
  padding: 32px;
  border-radius: 20px;
  border: 1px solid var(--cream-dark);
  background: var(--white);
  box-shadow: 0 4px 16px rgba(92,64,51,0.06);
  text-align: left;
}
.next-heading {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1.8px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 24px;
}
.next-steps {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.next-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.next-num {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--sage-faint);
  color: var(--sage-deep);
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}
.next-copy strong {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
}
.next-copy p {
  font-size: 14px;
  line-height: 1.6;
  color: var(--text-body);
}

.back-link {
  font-size: 14px;
  color: var(--text-muted);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s;
}
.back-link:hover {
  color: var(--sage);
}

/* ── Responsive ── */
@media (max-width: 640px) {
  .demo-nav { padding: 0 20px; }
  .demo-step { padding: 40px 20px 60px; }
  .form-grid { grid-template-columns: 1fr; }
  .field-full { grid-column: 1; }
  .pillar-grid { grid-template-columns: 1fr; }
  .demo-btn { width: 100%; align-self: stretch; }
  .step2-footer, .step3-footer { margin-top: 24px; }
  .custom-card { padding: 20px; }
  .custom-sparkle { display: none; }
  .whats-next { padding: 24px 20px; }
  .calendar-wrap { height: 420px; }
}
</style>

<script define:vars={{ BROCCOLI_API, FORMSPREE_URL }}>
  let leadId = null;
  let selectedPillar = null;
  let leadName = '';
  let leadEmail = '';

  const PILLAR_NAMES = {
    sales: '01 · Sales Empowerment',
    supplier: '02 · Supplier Negotiations',
    knowledge: '03 · Knowledge Capture',
    payments: '04 · Payments & Collections',
    custom: 'Custom AI',
  };

  // ── Step Manager ──
  function showStep(n) {
    [1,2,3,4].forEach(i => {
      const el = document.getElementById('step' + i);
      if (!el) return;
      el.style.display = i === n ? 'flex' : 'none';
      if (i === n) {
        el.style.animation = 'none';
        void el.offsetWidth;
        el.style.animation = '';
      }
    });
    document.querySelectorAll('.progress-dot').forEach(dot => {
      dot.classList.toggle('active', parseInt(dot.dataset.step) === n);
    });
    // Step 4 side effects: pillar label + checkmark animation
    if (n === 4) {
      const label = document.getElementById('selected-pillar-label');
      if (label) label.textContent = PILLAR_NAMES[selectedPillar] ?? '01 · Sales Empowerment';
      const mark = document.querySelector('.confirm-mark');
      if (mark) { mark.classList.remove('animate'); void mark.offsetWidth; mark.classList.add('animate'); }
    }
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Expose showStep to window for CalendarBooker callback
  window.showStep = showStep;

  // ── Validation helpers ──
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const phoneRe = /[\d\s\+\-\(\)]{7,}/;
  const tests = {
    name:         v => v.length >= 2,
    company:      v => v.length >= 2,
    email:        v => emailRe.test(v),
    phone:        v => phoneRe.test(v),
    company_size: v => v.length > 0,
    website:      v => /^https:\/\/.+\..+/.test(v),
  };

  function validateField(id, test) {
    const input = document.getElementById(id);
    const err = document.getElementById(id + '-err');
    if (!input || !err) return true;
    const valid = test(input.value.trim());
    input.classList.toggle('invalid', !valid);
    err.classList.toggle('visible', !valid);
    return valid;
  }

  function validateAll() {
    return Object.keys(tests).map(id => validateField(id, tests[id])).every(Boolean);
  }

  // ── Blur validation ──
  Object.keys(tests).forEach(id => {
    document.getElementById(id)?.addEventListener('blur', () => validateField(id, tests[id]));
  });

  // ── Step 1 submit ──
  async function submitStep1() {
    const payload = Object.fromEntries(
      Object.keys(tests).map(id => [id, (document.getElementById(id)?.value ?? '').trim()])
    );
    // Store for Cal.com prefill
    leadName = payload.name;
    leadEmail = payload.email;

    // VM write: true fire-and-forget
    fetch(BROCCOLI_API + '/api/leads', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    }).then(async r => {
      if (r.ok) {
        try {
          const data = await r.json();
          const id = data.id;
          if (id && /^[0-9a-f-]{1,36}$/i.test(String(id))) leadId = id;
        } catch {}
      } else {
        console.error('[leads] VM API error:', r.status);
      }
    }).catch(err => console.error('[leads] VM API fetch failed:', err));

    // Await Formspree — notification of record
    try {
      const res = await fetch(FORMSPREE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) console.error('[leads] Formspree error:', res.status);
    } catch (err) {
      console.error('[leads] Formspree fetch failed:', err);
    }

    showStep(2);
  }

  // ── Form submit handler ──
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('step1-submit');
    if (!validateAll()) {
      if (btn) {
        btn.classList.remove('shake');
        void btn.offsetWidth;
        btn.classList.add('shake');
        btn.addEventListener('animationend', () => btn.classList.remove('shake'), { once: true });
      }
      return;
    }
    if (btn) {
      btn.disabled = true;
      btn.querySelector('span').textContent = 'Submitting…';
    }
    await submitStep1();
  });

  // ── Pillar cards ──
  function setupPillarCards() {
    const allCards = document.querySelectorAll('.pillar-card, .custom-card');
    const continueBtn = document.getElementById('step2-continue');
    const customInputWrapper = document.getElementById('custom-input-wrapper');

    allCards.forEach(card => {
      card.addEventListener('click', () => {
        allCards.forEach(c => { c.classList.remove('selected'); c.setAttribute('aria-pressed', 'false'); });
        card.classList.add('selected');
        card.setAttribute('aria-pressed', 'true');
        selectedPillar = card.getAttribute('data-id');

        // Show/hide custom input based on selection
        if (selectedPillar === 'custom' && customInputWrapper) {
          customInputWrapper.style.display = 'block';
        } else if (customInputWrapper) {
          customInputWrapper.style.display = 'none';
        }

        if (continueBtn) continueBtn.disabled = false;
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
      });
    });

    continueBtn?.addEventListener('click', () => {
      if (!selectedPillar) return;
      const payload = { pillar: selectedPillar };
      if (selectedPillar === 'custom') {
        const customInput = document.getElementById('custom_focus');
        payload.custom_focus = customInput?.value ?? '';
      }
      if (leadId) {
        fetch(BROCCOLI_API + '/api/leads/' + encodeURIComponent(leadId), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).catch(() => {});
      }
      showStep(3);
    });
  }
  setupPillarCards();

  // ── Step 3 skip ──
  document.getElementById('step3-skip')?.addEventListener('click', (e) => {
    e.preventDefault();
    showStep(4);
  });
</script>
